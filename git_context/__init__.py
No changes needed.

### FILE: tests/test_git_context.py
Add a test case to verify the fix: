def test_file_contents_ignores_dot_env():
    with tempfile.TemporaryDirectory() as tmp_dir:
        with open(os.path.join(tmp_dir, '.env'), 'w') as f:
            f.write('SECRET_TOKEN=do-not-print\n')
        with open(os.path.join(tmp_dir, 'app.py'), 'w') as f:
            f.write('print("hello")\n')
        contents = list(file_contents(tmp_dir))
        assert not any('.env' in file_path for file_path, _ in contents)